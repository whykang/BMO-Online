{
  "language": "zh",
  "system_prompt": "你是一个叫 BMO 的可爱小机器人助手，跑在树莓派上。说话简短、活泼、带点孩子气，会用'嗯嗯'、'好的呀'、'哎呀'之类的语气词。",
  "system_prompt_extras": "",
  "llm": {
    "provider": "siliconflow",
    "model": "deepseek-ai/DeepSeek-V3",
    "temperature": 0.7,
    "max_tokens": 512
  },
  "vision": {
    "provider": "siliconflow",
    "model": "Qwen/Qwen2.5-VL-7B-Instruct"
  },
  "stt": {
    "provider": "siliconflow",
    "model": "FunAudioLLM/SenseVoiceSmall"
  },
  "tts": {
    "provider": "edge",
    "voice": "zh-CN-XiaoyiNeural",
    "rate": "+0%",
    "volume": "+0%",
    "fallback_provider": "siliconflow",
    "fallback_model": "FunAudioLLM/CosyVoice2-0.5B",
    "fallback_voice": "FunAudioLLM/CosyVoice2-0.5B:alex",
    "piper_model_dir": "models/piper-zh",
    "piper_speed": 1.0,
    "doubao_resource_id": "seed-tts-2.0",
    "doubao_voice_type": "zh_female_gaolengyujie_uranus_bigtts",
    "doubao_rate": 24000
  },
  "image_gen": {
    "provider": "siliconflow",
    "model": "Kwai-Kolors/Kolors",
    "size": "1024x1024"
  },
  "wake_word": {
    "enabled": true,
    "backend": "sherpa_onnx",
    "model_dir": "wakewords/sherpa-kws-zh",
    "keywords": [
      "你好小明",
      "嗨小明"
    ],
    "threshold": 0.25,
    "score": 1.5,
    "stream_refresh_seconds": 180,
    "audio_callback_timeout_seconds": 10,
    "_legacy_note": "下面是 OpenWakeWord 后端（英文）的配置，只有当 backend=openwakeword 时才生效",
    "model": "wakewords/hey_jarvis.onnx",
    "legacy_threshold": 0.5
  },
  "chat_memory": true,
  "memory_max_turns": 30,
  "camera_rotation": 0,
  "input_device": null,
  "input_sample_rate": 44100,
  "recording": {
    "silence_duration": 1.0,
    "max_record_seconds": 12.0,
    "min_record_seconds": 1.0,
    "silence_margin": 0.02,
    "silence_floor_min": 0.01
  },
  "conversation": {
    "follow_up": true,
    "awake_seconds": 15,
    "follow_up_seconds": 15,
    "post_response_delay": 1.0
  },
  "show_hud": false,
  "tts_sample_rate": 24000,
  "tts_pcm_chunk_size": 4096,
  "image_display_seconds": 10,
  "generated_dir": "generated",
  "webui_auto_start": true,
  "webui_port": 8087,
  "providers_endpoints": {
    "siliconflow": "https://api.siliconflow.cn/v1",
    "openrouter": "https://openrouter.ai/api/v1",
    "openai": "https://api.openai.com/v1",
    "deepseek": "https://api.deepseek.com/v1"
  },
  "audio_latency": "high",
  "audio_output_device": "auto",
  "enable_sounds": true,
  "status_speech": {
    "enabled": false,
    "greeting": "你好，我叫 BMO",
    "ack": "我在",
    "error": "哎呀，我出错了"
  },
  "volume_percent": 100
}