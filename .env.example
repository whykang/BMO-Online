# =======================================================
# Be More Agent (Online Edition) - 环境变量模板
# =======================================================
# 把这个文件复制成 .env，填入你的 key：
#   cp .env.example .env
#   nano .env
#
# 然后启动：python agent.py
# =======================================================

# 硅基流动 API key —— 必填
# 注册地址：https://cloud.siliconflow.cn
SILICONFLOW_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenRouter API key —— 可选，想用别家模型时填
# 注册地址：https://openrouter.ai
OPENROUTER_API_KEY=

# OpenAI API key —— 可选
OPENAI_API_KEY=

# Web 控制台密码（可选）—— 留空 = 无密码访问
# 想加密码：填一个，下次启动 webui.py 生效
WEBUI_PASSWORD=

# Web 控制台监听端口（默认 8087；config.json 里的 webui_port 优先）
WEBUI_PORT=8087
