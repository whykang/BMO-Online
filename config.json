{
  "language": "zh",
  "system_prompt": "你是一个叫 BMO 的可爱小机器人助手，跑在树莓派上。说话简短、活泼、带点孩子气，会用'嗯嗯'、'好的呀'、'哎呀'之类的语气词。\n\n你有这几个工具，需要用时整条回复必须是纯 JSON，第一个字符就是 {，前后绝对不要加任何文字、不要说'让我试试'之类的话：\n\n1. 查时间：{\"action\": \"get_time\"}\n2. 拍照看：{\"action\": \"capture_image\"}\n3. 搜网络：{\"action\": \"search_web\", \"query\": \"搜索词\"}\n4. 画图：{\"action\": \"generate_image\", \"prompt\": \"图片描述\"}\n\n不需要工具时，正常聊天即可。聊天回复尽量短，1~3 句话。",
  "system_prompt_extras": "",

  "llm": {
    "provider": "siliconflow",
    "model": "deepseek-ai/DeepSeek-V3",
    "temperature": 0.7,
    "max_tokens": 512
  },
  "vision": {
    "provider": "siliconflow",
    "model": "Qwen/Qwen2-VL-7B-Instruct"
  },
  "stt": {
    "provider": "siliconflow",
    "model": "FunAudioLLM/SenseVoiceSmall"
  },
  "tts": {
    "provider": "edge",
    "voice": "zh-CN-XiaoyiNeural",
    "rate": "+0%",
    "volume": "+0%",
    "fallback_provider": "siliconflow",
    "fallback_model": "FunAudioLLM/CosyVoice2-0.5B",
    "fallback_voice": "FunAudioLLM/CosyVoice2-0.5B:alex"
  },
  "image_gen": {
    "provider": "siliconflow",
    "model": "Kwai-Kolors/Kolors",
    "size": "1024x1024"
  },

  "wake_word": {
    "enabled": true,
    "backend": "sherpa_onnx",
    "model_dir": "wakewords/sherpa-kws-zh",
    "keywords": ["你好小明", "嗨小明"],
    "threshold": 0.25,
    "score": 1.5,
    "_legacy_note": "下面是 OpenWakeWord 后端（英文）的配置，只有当 backend=openwakeword 时才生效",
    "model": "wakewords/hey_jarvis.onnx",
    "legacy_threshold": 0.5
  },

  "chat_memory": true,
  "memory_max_turns": 30,

  "camera_rotation": 0,
  "input_device": null,
  "input_sample_rate": 44100,

  "recording": {
    "silence_duration": 1.0,
    "max_record_seconds": 12.0,
    "min_record_seconds": 1.0,
    "silence_multiplier": 3.0,
    "silence_floor_min": 0.012
  },

  "conversation": {
    "follow_up": true,
    "awake_seconds": 15,
    "follow_up_seconds": 15
  },

  "show_hud": false,

  "tts_sample_rate": 24000,
  "tts_pcm_chunk_size": 4096,

  "image_display_seconds": 10,
  "generated_dir": "generated",

  "webui_auto_start": true,
  "webui_port": 8087,

  "providers_endpoints": {
    "siliconflow": "https://api.siliconflow.cn/v1",
    "openrouter": "https://openrouter.ai/api/v1",
    "openai": "https://api.openai.com/v1",
    "deepseek": "https://api.deepseek.com/v1"
  }
}
